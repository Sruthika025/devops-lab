pipeline {
    agent any

    stages {

        stage('Checkout from GitHub') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/Sruthika025/devops-lab.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                docker build -t devops-lab:${BUILD_NUMBER} .
                docker tag devops-lab:${BUILD_NUMBER} Sruthika025/devops-lab:${BUILD_NUMBER}
                '''
            }
        }

        stage('Run Container') {
            steps {
                sh '''
                docker rm -f html-container || true
                docker run -d -p 3000:80 --name html-container Sruthika025/devops-lab:${BUILD_NUMBER}
                '''
            }
        }
    }
}
